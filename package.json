{
  "name": "dnpxia",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @dnpxia/web dev",
    "dev:api": "pnpm --filter @dnpxia/api dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @dnpxia/api db:generate",
    "db:migrate": "pnpm --filter @dnpxia/api db:migrate",
    "db:seed": "pnpm --filter @dnpxia/api db:seed"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
